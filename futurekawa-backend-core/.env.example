# Database Configuration
DB_USER=postgres
DB_PASSWORD=secret

# JWT Configuration
JWT_SECRET=futurekawa-secret-key-for-jwt-token-generation-and-validation-2024
JWT_EXPIRATION=86400000

# MQTT Configuration
MQTT_BROKER=tcp://mosquitto:1883
MQTT_CLIENT_ID=futurekawa-core
MQTT_TOPIC_PATTERN=futurekawa/warehouse/+/measurements
MQTT_QOS=1
MQTT_RETAIN=false

# Spring Profiles (opcional)
# SPRING_PROFILES_ACTIVE=dev

# Mail Configuration (optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
